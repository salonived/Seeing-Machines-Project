def query_engine(text_string, top_k_val, similarity_cutoff):
    text_token = model.encode_text(clip.tokenize([text_string])).to(device)
    text_token /= text_token.norm(dim=-1, keepdim=True)
    
    similarities = (image_embeddings_matrix @ text_token.T).squeeze(1).tolist()
    scored_results = sorted(zip(filenames, similarities), key=lambda x: x[1], reverse=True)
    
    filtered = [item for item in scored_results if item[1] >= similarity_cutoff]
    return filtered[:top_k_val]
